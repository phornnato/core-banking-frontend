@model RoleViewModel

<div class="card shadow">

    <div class="card-header">
        Edit Role
    </div>

    <div class="card-body">

        <form asp-action="Edit">

            <input asp-for="Id" hidden />

            <div class="mb-3">

                <label>Title</label>

                <input asp-for="Title"
                       class="form-control" />

            </div>

            <div class="mb-3">

                <label>Description</label>

                <textarea asp-for="Description"
                          class="form-control"></textarea>

            </div>

            <button class="btn btn-primary">
                Update
            </button>

        </form>

    </div>

</div>